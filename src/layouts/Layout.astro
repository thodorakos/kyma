---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "ΚΥΜΑ ΣΤΟ ΧΥΜΑ — Ψητομεζεδοπωλείο" } = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Κύμα στο Χύμα — Ψητομεζεδοπωλείο. Εκεί που η σούβλα περιστρέφεται με αγάπη και το φαγητό έχει γεύση παρέα, κάρβουνο και μεράκι." />
    <link rel="icon" type="image/jpeg" href="/kymastoxyma_logo.jpg" />
    <title>{title}</title>
</head>
<body>
    <slot />
</body>

<script>
  document.addEventListener('click', (e) => {
    const link = e.target.closest('a[href^="#"]');
    if (!link) return;
    const href = link.getAttribute('href');
    if (!href || href === '#') return;

    const target = document.querySelector(href);
    if (!target) return;

    e.preventDefault();

    const nav = document.querySelector('nav');
    const navHeight = nav ? nav.offsetHeight : 0;
    const top = target.getBoundingClientRect().top + window.scrollY - navHeight - 10;

    window.scrollTo({ top, behavior: 'smooth' });
    history.pushState(null, '', href);

    target.classList.remove('section-target');
    let raf = null;
    let prevY = window.scrollY;
    function detectStop() {
      const curY = window.scrollY;
      if (curY === prevY) {
        target.classList.add('section-target');
        if (raf) cancelAnimationFrame(raf);
        return;
      }
      prevY = curY;
      raf = requestAnimationFrame(detectStop);
    }
    raf = requestAnimationFrame(detectStop);
    setTimeout(() => {
      target.classList.add('section-target');
      if (raf) cancelAnimationFrame(raf);
    }, 1200);

    document.querySelectorAll('nav a[href^="#"]').forEach(a => {
      a.classList.toggle('text-orange-bright', a.getAttribute('href') === href);
    });
  });

  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('nav a[href^="#"]');

  function setActiveLink(hash) {
    navLinks.forEach(link => {
      link.classList.toggle('text-orange-bright', link.getAttribute('href') === hash);
    });
  }

  if (location.hash) setActiveLink(location.hash);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        setActiveLink('#' + entry.target.id);
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  sections.forEach(s => observer.observe(s));
</script>
</html>
