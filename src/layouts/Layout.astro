---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "ΚΥΜΑ ΣΤΟ ΧΥΜΑ — Ψητομεζεδοπωλείο" } = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Κύμα στο Χύμα — Ψητομεζεδοπωλείο. Εκεί που η σούβλα περιστρέφεται με αγάπη και το φαγητό έχει γεύση παρέα, κάρβουνο και μεράκι." />
    <link rel="icon" type="image/jpeg" href="/kymastoxyma_logo.jpg" />
    <title>{title}</title>
</head>
<body>
    <slot />
</body>
</html>
